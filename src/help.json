{
  "title": "Dub FX",
  "children": [
    {
      "title": "Quick Start",
      "lines": [
        "Dub-oriented overtake FX.",
        "Top row = desk controls",
        "1 High kill  2 Mid kill",
        "3 Low kill   4 Dub/Sub kill",
        "8 toggles LPF/HPF for E8",
        "",
        "Row 2 = Echo lane",
        "Pad 1 is main Echo",
        "Pads 2-8 are macro placeholders",
        "",
        "Row 3 = Reverb lane",
        "Pad 1 is main Reverb",
        "",
        "Row 4 = Dub Siren lane",
        "Pads 1-8 now trigger sample bank",
        "Bank loaded from siren_1..siren_8",
        "Live bank swapping is next",
        "",
        "Hold Echo/Reverb/Siren pad",
        "to remap the knobs"
      ]
    },
    {
      "title": "Dub Layout",
      "lines": [
        "Row 4: Dub repeats",
        "  1/4  1/8  1/16 Trip",
        "  Stut Scat Rev  Stop",
        "",
        "Row 3: Filters/Sirens",
        "  LP   HP   Up   Down",
        "  Reso Phas Flan Auto",
        "",
        "Row 2: Tape/Verb",
        "  T14  TD8  P14  PD8",
        "  Room Hall Dub  Sprg",
        "",
        "Row 1: Dirt/Rhythm",
        "  Crush Down Drv Duck",
        "  Trem Sub  Vnyl Brak"
      ]
    },
    {
      "title": "MIDImix",
      "lines": [
        "Default MIDImix map:",
        "Faders 1-4 = High/Mid/Low/Sub",
        "Fader 5 = Master",
        "Fader 6 = Echo send",
        "Fader 7 = Verb send",
        "Fader 8 = Filter",
        "Rec = momentary throws",
        "Mute = latch throws",
        "Solo 1-4 = iso kills",
        "Solo 5 = bypass"
      ]
    }
  ]
}
